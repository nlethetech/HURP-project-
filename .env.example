# Copy to .env and fill in. Never commit .env (.gitignore already excludes it).

# ACLED API (https://acleddata.com) — 2025 OAuth2 password-grant.
# Register a free myACLED account, then put your login email + password here.
# The acquisition script exchanges these for a 24h access token at
# https://acleddata.com/oauth/token (client_id=acled, scope=authenticated).
ACLED_EMAIL=
ACLED_PASSWORD=
