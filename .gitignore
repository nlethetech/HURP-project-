# Data is reproducible from scripts; never commit it.
# Exception: per-source MANIFEST.txt provenance records (URL, retrieval date, sha256) stay in git.
data/raw/*
!data/raw/*/
data/raw/*/*
!data/raw/*/MANIFEST.txt
!data/raw/.gitkeep
data/interim/
data/processed/
!data/**/.gitkeep

# Credentials
.env

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
.ipynb_checkpoints/

# OS
.DS_Store
